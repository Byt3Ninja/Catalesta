includes:
    - vendor/larastan/larastan/extension.neon

parameters:
    level: 6
    paths:
        - app
    tmpDir: storage/phpstan
    ignoreErrors:
        -
            identifier: trait.unused
            # ImmutableWhenPublished is intentionally unused at this phase.
            # It will be adopted by StageVersion in M3.1 — remove this entry then.
            path: app/Shared/Versioning/ImmutableWhenPublished.php
