APP_NAME=Catalesta
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# --- Database: PostgreSQL (docs/02, docs/13). Storage in UTC. ---
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=catalesta
DB_USERNAME=postgres
DB_PASSWORD=password

# --- Sessions, cache, queues, locks: Redis (docs/02). predis avoids a C ext. ---
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
QUEUE_CONNECTION=redis
CACHE_STORE=redis
# CACHE_PREFIX=

REDIS_CLIENT=predis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# --- Object storage: S3-compatible (MinIO locally). Private buckets + signed URLs. ---
FILESYSTEM_DISK=s3
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=catalesta
AWS_ENDPOINT=http://minio:9000
AWS_URL=http://localhost:9000/catalesta
AWS_USE_PATH_STYLE_ENDPOINT=true

# --- Mail (Mailpit locally) ---
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@catalesta.test"
MAIL_FROM_NAME="${APP_NAME}"

# --- Startup Gate identity (mock for the initial phase; docs/10). ---
# Swap IDENTITY_PROVIDER=startup_gate + real URLs at Phase 12 — adapter/config only.
IDENTITY_PROVIDER=mock
OIDC_ISSUER=http://startup-gate-mock:8080
OIDC_CLIENT_ID=program-platform
OIDC_CLIENT_SECRET=local-secret
OIDC_REDIRECT_URI=http://localhost:3000/auth/callback
PROFILE_API_BASE_URL=http://startup-gate-mock:8080/api/v1

VITE_APP_NAME="${APP_NAME}"

# --- Dual role: platform (default) or mock ---
APP_ROLE=platform

# Mock signing keys are generated by `php artisan sg-mock:keys` for local dev.
SG_MOCK_KID=sg-mock-key-1
SG_MOCK_WEBHOOK_SECRET=mock-webhook-secret

# Sanctum SPA
SANCTUM_STATEFUL_DOMAINS=localhost:3000
SESSION_DOMAIN=localhost
