# Root .env — consumed ONLY by Docker Compose for variable interpolation.
# The Laravel application is configured by backend/.env (see backend/.env.example),
# and the React app by frontend/.env (see frontend/.env.example). Do not duplicate
# application config here.
#
# Compose interpolates ${APP_KEY} into the startup-gate-mock service. Generate one with:
#   docker compose run --rm laravel-api php artisan key:generate --show
APP_KEY=
